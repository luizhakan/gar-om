DATABASE_URL="postgresql://admin:admin@localhost:5432/garcom?schema=public"
PORT=3001
AUTH_SECRET=
FRONTEND_URL=http://localhost:5173

# Mercado Pago Configuration
# ===========================

# Access Token do Mercado Pago (obrigatório)
# Para teste: use seu TEST_ACCESS_TOKEN
# Para produção: use seu PROD_ACCESS_TOKEN
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MERCADO_PAGO_ACCESS_TOKEN=TEST-your-test-access-token-here

# Public Key do Mercado Pago (usado no frontend)
# Para teste: use seu TEST_PUBLIC_KEY
# Para produção: use seu PROD_PUBLIC_KEY
MERCADO_PAGO_PUBLIC_KEY=TEST-your-test-public-key-here

# Secret para validação de webhooks (opcional mas recomendado)
# Este valor é gerado automaticamente ao configurar webhooks em "Suas integrações"
# Sem ele, as notificações não serão validadas por segurança
MERCADO_PAGO_WEBHOOK_SECRET=your-webhook-secret-here

# URL completa do webhook (obrigatório em produção)
# Deve ser uma URL HTTPS acessível publicamente
# Exemplo: https://seudominio.com/webhooks/mercadopago
MERCADO_PAGO_WEBHOOK_URL=https://your-domain.com/webhooks/mercadopago

# URL base da API (usado para construir links)
API_BASE_URL=http://localhost:3001

# ===========================================
# Como obter suas credenciais:
# ===========================================
# 1. Acesse: https://www.mercadopago.com.br/developers/panel/app
# 2. Crie ou selecione uma aplicação
# 3. Na seção "Credenciais":
#    - Use as credenciais de TESTE durante desenvolvimento
#    - Use as credenciais de PRODUÇÃO apenas quando for para o ar
#
# Como configurar webhooks:
# ===========================================
# 1. No painel, vá em "Suas integrações" > Sua aplicação
# 2. Clique em "Webhooks"
# 3. Configure a URL (deve ser HTTPS em produção):
#    - Ambiente de teste: pode usar ngrok temporariamente
#    - Produção: sua URL real
# 4. Selecione o evento "Pagamentos"
# 5. Copie a chave secreta gerada
#
# Testando com ngrok (desenvolvimento):
# ===========================================
# 1. Instale ngrok: https://ngrok.com/download
# 2. Execute: ngrok http 3001
# 3. Use a URL gerada (ex: https://abc123.ngrok.io)
# 4. Configure: MERCADO_PAGO_WEBHOOK_URL=https://abc123.ngrok.io/webhooks/mercadopago
